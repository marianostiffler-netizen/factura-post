# ===========================================
#  Variables de entorno — factura-pos
# ===========================================

# --- Login por PIN (4 dígitos) ---
# El acceso es por PIN, no hay tabla de usuarios.
PIN_CODE=1234

# --- Base de datos Supabase (Project Settings > Database > Connection string > URI) ---
# Drizzle (postgres-js) se conecta por aquí. Reemplazar [PASSWORD] y host.
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Supabase API (se usa el proyecto solo como Postgres; estas quedan por si
#     más adelante sumás Storage u otras features) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# --- Comercio (datos para la factura) ---
NEXT_PUBLIC_COMERCIO_NOMBRE="Mi Comercio"
NEXT_PUBLIC_COMERCIO_DIRECCION=""
NEXT_PUBLIC_COMERCIO_CUIT=""
